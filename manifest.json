{
"manifest_version": 3,
"name": "Panel-Helper-Diamond",
"version": "1.1",
"description": "(Ahura) Diamond",
"permissions": [
"activeTab",
"storage"
],

"action": {
"default_title": "Panel Helper",
"default_popup": "popup.html"
},

"content_scripts": [
{
"matches": ["<all_urls>"],
"js": ["content.js"]
}
]
}
